# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
frontend/dist
backend/dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules
.pnpm-store

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
# Env files — never commit real env values. Only .example templates may be committed.
/.env
/.env.*
!/.env.example
!/config/env.example
# Per-package envs (Vite auto-loads frontend/.env*)
frontend/.env
frontend/.env.*
!frontend/.env.example
backend/.env
backend/.env.*
!backend/.env.example
/.sass-cache
/connect.lock
/coverage
*.log
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Vite / tooling caches
frontend/.vite/
.turbo/
.eslintcache
.pnpm-debug.log*

.local/
.agents/
.claude/
.claude-flow/
.swarm/
.mcp.json
ruvector.db
memory/
*.log
zipFile/
*.zip
PageSpeed Insights.html

# Firebase service account (sensitive credentials)
*.firebase-adminsdk*.json
ruflo
.kiro/settings/mcp.json
.kiro
.vscode
.husky

# Load-test exports / audit dumps (operator-local, never commit)
report*.json
report (*).json
*.har
PageSpeed*.json

# AI coding tools — local config, never commit
.aider*/
.cursor/
.windsurf/
.continue/
.codex/

# Local SQLite databases (e.g. ruvector.db)
*.sqlite
*.sqlite3

# ── Heavy binaries / archives / local DBs — keep the repo + CI lean ──────────
# (*.zip and *.sqlite* are already ignored above; this hardens the rest.)
*.db
*.db-wal
*.db-shm
*.tar
*.tar.gz
*.tgz
*.gz
*.7z
*.rar
*.bak
*.dump
*.sql.gz
