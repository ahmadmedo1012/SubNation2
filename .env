# =============================================================================
# SubNation - Environment Configuration
# =============================================================================
# Copy this file to `.env` at the repo root (or `config/.env.local`) and edit
# the values. Nothing else in the codebase should need to change between
# hosting environments (local, Docker, VPS, Vercel, cPanel, Replit, ...).
#
# Load order (later wins, shell exports always win):
#   1. .env            2. .env.local
#   3. config/.env     4. config/.env.local
# =============================================================================


# -----------------------------------------------------------------------------
# Database  (required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string used by the API and Drizzle migrations.
DATABASE_URL=postgresql://neondb_owner:npg_ZCsxjW8rQz3o@ep-noisy-dream-aqltup8y-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DB_POOL_MAX=5
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000


# -----------------------------------------------------------------------------
# Runtime / Ports  (optional)
# -----------------------------------------------------------------------------
# These are *preferences*. The local runner auto-picks the next free port
# (up to +50) if the preferred one is busy, so you never need to edit them
# to resolve a conflict. On most PaaS providers, leave PORT unset and let
# the platform inject it.
PORT=
API_PORT=8080
FRONTEND_PORT=5173

# Base path the SPA is served under. Use "/" for root domains,
# "/app/" for sub-path deployments (e.g. cPanel).
BASE_PATH=/

# Public app origin used by OAuth callbacks and absolute links in emails/etc.
# In `npm run dev` this is auto-filled with the chosen frontend origin when
# APP_URL is left blank.
APP_URL=https://subnation2.onrender.com

# Comma-separated list of origins allowed by CORS. Leave empty in dev to
# allow all; set to your public origin(s) in production.
APP_ORIGINS=https://subnation2.onrender.com


# -----------------------------------------------------------------------------
# Auth  (required in production)
# -----------------------------------------------------------------------------
# Must be a long random string in production. The API also accepts JWT_SECRET
# as an alias and will copy it into SESSION_SECRET at startup.
SESSION_SECRET=46d26db992e448684077528ca2b74a77ffc22c83d627b9ea3ef302772617bec6ee1815db9e0c84e2e9d2171e4933e9191e252d01481cd8b893fc841f9cedd69d

# AES-256-GCM key for encrypting inventory account_passwords at-rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=f83bbca6bf3099c727185a23eee27c4e67e6af8eb09ef56a147965784fb221bb

# Optional OAuth / notification integrations.
GOOGLE_CLIENT_ID=
TELEGRAM_BOT_TOKEN=8710813831:AAFaP7BvesYP_OSE_utqwXO69Lugm5_ghS0
TELEGRAM_CHAT_ID=-1003878819089


# -----------------------------------------------------------------------------
# Firebase Authentication  (backend)
# -----------------------------------------------------------------------------
# Enable Firebase Admin SDK for token verification
FIREBASE_AUTH_ENABLED=true
FIREBASE_PROJECT_ID=subnation-2571e
# Service account JSON (single-line escaped, or use FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY)
# Configure FIREBASE_SERVICE_ACCOUNT_JSON in Render environment variables
# Format: {"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
FIREBASE_SERVICE_ACCOUNT_JSON=


# -----------------------------------------------------------------------------
# Frontend build-time variables  (prefixed VITE_, embedded into the bundle)
# -----------------------------------------------------------------------------
# Absolute backend origin for split deployments (e.g. Vercel frontend + VPS
# API). Leave EMPTY when the backend serves the SPA from the same origin —
# the client will use relative /api paths, which is the default and works
# everywhere.
VITE_API_URL=https://subnation2.onrender.com

# Public-facing app name (optional, available to the React app).
VITE_APP_NAME=SubNation

# Public Google OAuth client id (safe to ship in the bundle).
VITE_GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Firebase Authentication  (frontend)
# -----------------------------------------------------------------------------
# Enable Firebase client SDK
VITE_FIREBASE_AUTH_ENABLED=true
# Firebase web app configuration
VITE_FIREBASE_API_KEY=AIzaSyDoQhcUbqwr0E6qws5vj2vwBNyDEq1EMsQ
VITE_FIREBASE_AUTH_DOMAIN=subnation-2571e.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=subnation-2571e
VITE_FIREBASE_STORAGE_BUCKET=subnation-2571e.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=288562976125
VITE_FIREBASE_APP_ID=1:288562976125:web:4ebf25358e603c3d4ea814
VITE_FIREBASE_MEASUREMENT_ID=G-RKRV3ZC3MF
VITE_FIREBASE_DATABASE_URL=https://subnation-2571e-default-rtdb.firebaseio.com


# -----------------------------------------------------------------------------
# Observability / misc  (optional)
# -----------------------------------------------------------------------------
# NODE_ENV is set automatically by the dev/start scripts.
# LOG_LEVEL: trace | debug | info | warn | error | fatal
LOG_LEVEL=info


# -----------------------------------------------------------------------------
# Neon MCP Server (optional - for direct database access via MCP)
# -----------------------------------------------------------------------------
# Get your API key from https://console.neon.tech/settings/api-keys
# Required for Neon MCP server integration
NEON_API_KEY=napi_pahvbif4cww0me5xi186mkjfqtgnmel39k0p4ctdl5m8xngnf629hnft1b33w5q


# -----------------------------------------------------------------------------
# Render MCP Server (optional - for Render deployment management via MCP)
# -----------------------------------------------------------------------------
# Get your API key from https://dashboard.render.com/account/settings/api-keys
# Required for Render MCP server integration
RENDER_API_KEY=rnd_ITSx4oLNS8fO9MLDKeWduFvVYAB45


# -----------------------------------------------------------------------------
# Seed script defaults  (used by `npm run db:seed`)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SubNation@2026
ADMIN_RESET_PASSWORD=false

