{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm install for this workspace\" >&2; exit 1 ;; esac'",
    "dev": "pnpm --filter @workspace/scripts dev",
    "build": "pnpm run lint && pnpm run typecheck && pnpm --filter @workspace/api-server run build",
    "start": "pnpm --filter @workspace/scripts start",
    "db:push": "pnpm --filter @workspace/db push",
    "db:seed": "pnpm --filter @workspace/scripts seed",
    "codegen": "pnpm --filter @workspace/api-spec codegen",
    "lint": "eslint backend frontend shared scripts",
    "lint:fix": "eslint backend frontend shared scripts --fix",
    "format": "prettier --write .",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter @workspace/api-server --filter @workspace/subnation --filter @workspace/scripts --if-present run typecheck",
    "prepare": "husky",
    "validate:cwv": "lhci autorun --collect.numberOfRuns=3",
    "validate:suite": "tsx scripts/validate.ts"
  },
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.2"
  }
}
