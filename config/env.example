# =============================================================================
# SubNation - Environment Configuration
# =============================================================================
# Copy this file to `.env` at the repo root (or `config/.env.local`) and edit
# the values. Nothing else in the codebase should need to change between
# hosting environments (local, Docker, VPS, Vercel, cPanel, Replit, ...).
#
# Load order (later wins, shell exports always win):
#   1. .env            2. .env.local
#   3. config/.env     4. config/.env.local
# =============================================================================


# -----------------------------------------------------------------------------
# Database  (required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string used by the API and Drizzle migrations.
# Use the **direct** Neon URL (not the -pooler one) on Render free tier —
# pgbouncer connections drop intermittently from Render's shared NAT.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DB_POOL_MAX=15
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=30000


# -----------------------------------------------------------------------------
# Redis  (required for production; in-memory fallback in dev)
# -----------------------------------------------------------------------------
# Used by:
#   - rate-limit-redis (apiLimiter, authLimiter, OTP limiters)
#   - alerting service dedup + global rate-limit windows
#   - scheduler-coordinator leader lock
#   - worker:heartbeat key (15 s)
#   - Socket.IO Redis adapter
# Fail-closed in production: if REDIS_URL is set but the connection errors,
# the process exits 1 rather than serving traffic with broken rate-limits.
REDIS_URL=


# -----------------------------------------------------------------------------
# Runtime / Ports  (optional)
# -----------------------------------------------------------------------------
# These are *preferences*. The local runner auto-picks the next free port
# (up to +50) if the preferred one is busy, so you never need to edit them
# to resolve a conflict. On most PaaS providers, leave PORT unset and let
# the platform inject it.
PORT=
API_PORT=8080
FRONTEND_PORT=5173

# Base path the SPA is served under. Always "/" for Render deployment.
BASE_PATH=/

# Public app origin used by OAuth callbacks and absolute links in emails/etc.
# In `npm run dev` this is auto-filled with the chosen frontend origin when
# APP_URL is left blank.
APP_URL=

# Comma-separated list of origins allowed by CORS. Leave empty in dev to
# allow all; set to your public origin(s) in production.
APP_ORIGINS=


# -----------------------------------------------------------------------------
# Auth  (required in production)
# -----------------------------------------------------------------------------
# Must be ≥ 32 random characters in production (the API throws at boot if
# shorter). Generate with:
#   openssl rand -base64 64 | tr -d '\n'
SESSION_SECRET=replace-with-a-long-random-production-secret

# AES-256-GCM key for encrypting inventory account_passwords at-rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-hex-characters

# Optional OAuth / notification integrations.
GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Telegram — TWO independent integrations
# -----------------------------------------------------------------------------
# Operational bot (low-stock alerts, new-order notifications, alerting
# service). Set BOTH variables to enable. Configure in @BotFather and
# add the chat where alerts should land.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram LOGIN (sign-in / sign-up via Telegram Login Widget) is NOT
# configured via env vars — credentials are stored in the database
# under the `auth.telegram` system-settings key and managed entirely
# through the admin UI:
#
#   1. /admin/settings → Auth providers → Telegram → fill bot_username
#      + bot_token (from @BotFather) → toggle enabled=true → save.
#
#   2. In @BotFather:
#        /setdomain → choose bot → enter "subnation.ly"
#      (Telegram only honours widget logins for registered domains.)
#
# After both steps the provider list endpoint returns Telegram and a
# Telegram button auto-appears on /login + /register. No redeploy.

# -----------------------------------------------------------------------------
# Firebase Auth  (optional — enables Google Sign-In)
# -----------------------------------------------------------------------------
# Powers ONLY the Google login flow. Firebase Phone OTP has been
# permanently retired in favour of WhatsApp OTP — the backend hard-rejects
# any token with sign_in_provider="phone".
#
# Server-side: Firebase Admin SDK validates ID tokens at /api/auth/firebase/*.
# `FIREBASE_SERVICE_ACCOUNT_JSON` is the FULL JSON content of the admin
# service-account key, single-line escaped. Generate from:
#   Firebase Console → Project settings → Service accounts → Generate key
FIREBASE_AUTH_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Client-side: the Firebase Web SDK reads these at runtime via Vite's
# import.meta.env. The web API key is public-by-design (gated by
# Authorized Domains in Firebase Console).
# https://firebase.google.com/docs/projects/api-keys
VITE_FIREBASE_AUTH_ENABLED=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_URL=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). When unset, the
# GA loader in frontend/src/lib/analytics.ts is a no-op — safe default
# for local dev, CI, and unconfigured deployments. Typically the same
# value as VITE_FIREBASE_MEASUREMENT_ID (Firebase auto-creates a linked
# GA4 stream) but kept separate so analytics can be toggled without
# touching the Firebase config. The CSP in backend/src/app.ts already
# allowlists the gtag.js + collect endpoints.
VITE_GA_TRACKING_ID=


# -----------------------------------------------------------------------------
# WhatsApp OTP via OpenWA  (optional — enables phone registration + login
# via WhatsApp text delivery). Phase 1 wires registration; login + 2FA
# reuse the same machinery in later phases. This is the SOLE phone-OTP
# path — Firebase Phone OTP has been permanently retired.
#
# When BOTH variables are unset, the WhatsApp endpoints respond with
# 503 `gateway_disabled` and the existing auth methods are unaffected.
#
# WHATSAPP_OTP_BASE_URL — full base URL of the OpenWA REST API
# WHATSAPP_OTP_API_KEY  — the api_key the OpenWA instance was launched
#                         with. Treat as a secret. Never logged. Never
#                         returned to clients.
# WHATSAPP_OTP_SESSION  — either an existing OpenWA session id (sess_…)
#                         or a session name (3–50 chars, alphanumeric +
#                         hyphens). When a name is given and no session
#                         with that name exists yet, the backend will
#                         create + start one on first send; an operator
#                         then has to scan the QR via the OpenWA
#                         dashboard before OTPs can flow.
# WHATSAPP_OTP_AUTO_CREATE_SESSION — optional. Default ON. Set to
#                         "false" to require sessions be provisioned
#                         out-of-band (no auto-create on first send).
# -----------------------------------------------------------------------------
WHATSAPP_OTP_BASE_URL=
WHATSAPP_OTP_API_KEY=
WHATSAPP_OTP_SESSION=
# WHATSAPP_OTP_AUTO_CREATE_SESSION=true


# -----------------------------------------------------------------------------
# Frontend build-time variables  (prefixed VITE_, embedded into the bundle)
# -----------------------------------------------------------------------------
# Absolute backend origin for split deployments (e.g. Vercel frontend + VPS
# API). Leave EMPTY when the backend serves the SPA from the same origin —
# the client will use relative /api paths, which is the default and works
# everywhere.
VITE_API_URL=

# Public-facing app name (optional, available to the React app).
VITE_APP_NAME=SubNation

# Public Google OAuth client id (safe to ship in the bundle).
VITE_GOOGLE_CLIENT_ID=


# -----------------------------------------------------------------------------
# Observability / misc  (optional)
# -----------------------------------------------------------------------------
# NODE_ENV is set automatically by the dev/start scripts.
# LOG_LEVEL: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Sentry — backend
SENTRY_DSN=
# Optional CLI source-map upload (Render-side build only; never committed)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Convenience link surfaced by /api/admin/observability/summary
SENTRY_DASHBOARD_URL=
RENDER_DASHBOARD_URL=
NEON_DASHBOARD_URL=

# /api/metrics auth (constant-time compared)
METRICS_ADMIN_TOKEN=

# Phase 3 alerting (operational alerts, separate from business webhooks)
ALERTING_ENABLED=true
DISCORD_WEBHOOK_URL=
GENERIC_ALERT_WEBHOOK_URL=

# Anomaly-detection pipeline (003-anomaly-detection).
# Default false = pipeline scores nothing and writes no risk_events
# rows; flip to true once Foundational lands and you want the
# rules engine to start producing scores. Safe-by-default per
# spec §1 Edge Cases ("scoring service down ⇒ rules-only fallback,
# never block legitimate customers").
RISK_PIPELINE_ENABLED=false

# Worker-tier migration switch.
# Default empty/false = the web process runs heartbeat + alerting evaluator +
# cron jobs under a Redis-backed leader lock (single-leader across web replicas).
# Set to "true" once a dedicated `subnation-worker` Render service exists so
# the web tier stops running them and the worker owns them.
DISABLE_WEB_SCHEDULERS=

# Boot-time schema migration switch.
# Default empty/false = on every cold start, server.ts runs
# runMigrations() under a Redis NX EX distributed lock so only one
# instance per cluster reconciles schema. All migration statements
# are idempotent (IF NOT EXISTS / IF EXISTS / DROP NOT NULL).
# Set to "true" ONLY for emergency rollbacks where a migration shipped
# in a release is broken and you need to bring up the previous binary
# against the newer schema. Production is fail-fast on critical
# migration errors when this is unset/false.
DISABLE_BOOT_MIGRATIONS=

# Sentry — frontend (Vite-public; DSN is public by design)
VITE_SENTRY_DSN=
VITE_RELEASE_SHA=
VITE_APP_VERSION=
VITE_APP_ORIGIN=


# -----------------------------------------------------------------------------
# Seed script defaults  (used by `npm run db:seed`)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-before-running-seed
ADMIN_RESET_PASSWORD=false
