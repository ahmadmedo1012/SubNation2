# Copy the values you need into .env or config/.env.local.

# PostgreSQL connection used by the API and Drizzle.
DATABASE_URL=postgres://user:password@127.0.0.1:5432/subnation

# Optional local port preferences. The root runner will move to the next
# available port when either one is occupied.
API_PORT=8080
FRONTEND_PORT=5173
BASE_PATH=/

# Public app URL for OAuth callbacks. In local dev, npm run dev fills this
# automatically with the chosen frontend origin when APP_URL is not set.
APP_URL=http://127.0.0.1:5173
APP_ORIGINS=http://127.0.0.1:5173

# Auth and integrations.
SESSION_SECRET=change-me-before-production
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Seed script defaults.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SubNation@2026
