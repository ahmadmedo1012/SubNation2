# -----------------------------------------------------------------------------
# Frontend-only env file.
#
# Only used when the frontend is deployed separately (e.g. Vercel / Netlify
# with the repo rooted at /frontend). For a full-stack deploy where the API
# serves the SPA, these variables live in the root `.env` — see
# `config/env.example`.
#
# Only `VITE_*` variables are exposed to the browser bundle; never put
# secrets here.
# -----------------------------------------------------------------------------

# Absolute backend origin, e.g. https://api.example.com.
# Leave empty if the frontend and backend share the same origin.
VITE_API_URL=

# Public-facing app name.
VITE_APP_NAME=SubNation

# Public Google OAuth client id.
VITE_GOOGLE_CLIENT_ID=
