# -----------------------------------------------------------------------------
# Frontend-only env file.
#
# Only used when the frontend is deployed separately (e.g. Vercel / Netlify
# with the repo rooted at /frontend). For a full-stack deploy where the API
# serves the SPA, these variables live in the root `.env` — see
# `config/env.example`.
#
# Only `VITE_*` variables are exposed to the browser bundle; never put
# secrets here.
# -----------------------------------------------------------------------------

# Absolute backend origin, e.g. https://api.example.com.
# Leave empty if the frontend and backend share the same origin.
VITE_API_URL=

# Public-facing app name.
VITE_APP_NAME=SubNation

# Public Google OAuth client id.
VITE_GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Sentry (frontend)
# -----------------------------------------------------------------------------
# DSN is *public by design* (Sentry treats it as a write-only key). The SDK
# falls back to the project's known DSN if this is unset; set this only when
# pointing the frontend at a different Sentry project.
VITE_SENTRY_DSN=

# Optional — display version / release tag in the Sentry dashboard. Use the
# Render commit SHA short form (first 7 chars). If unset, instrument.ts
# falls back to `import.meta.env.MODE`.
VITE_RELEASE_SHA=
VITE_APP_VERSION=

# Build-time only (consumed by @sentry/vite-plugin). Source maps upload runs
# only when SENTRY_AUTH_TOKEN is provided. Never expose these in the bundle.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
