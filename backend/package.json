{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch ./src/index.ts",
    "build": "node ./build.mjs && pnpm --dir .. --filter @workspace/subnation run build",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "start:worker": "node --enable-source-maps ./dist/worker.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@sentry/node": "^10.53.1",
    "@sentry/profiling-node": "^10.53.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "argon2": "^0.44.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.4.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "otplib": "^13.4.0",
    "pino": "^9",
    "pino-http": "^10",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@sentry/cli": "^2.41.1",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "@vitest/ui": "^4.1.6",
    "drizzle-zod": "0.8.3",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "vitest": "^4.1.6"
  }
}
